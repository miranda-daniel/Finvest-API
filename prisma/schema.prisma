// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   Int            @id @default(autoincrement())
  email                String         @unique
  password             String
  firstName            String
  lastName             String
  isActive             Boolean        @default(true)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  portfolios           Portfolio[]
  refreshTokens        RefreshToken[]
  favoritePortfolioId  Int?
  favoritePortfolio    Portfolio?     @relation("UserFavoritePortfolio", fields: [favoritePortfolioId], references: [id], onDelete: SetNull)
}

// A portfolio groups holdings under a name (e.g. "Long Term", "Trading")
model Portfolio {
  id           Int       @id @default(autoincrement())
  name         String
  description  String?
  userId       Int
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings     Holding[]
  favoritedBy  User[]    @relation("UserFavoritePortfolio")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// A holding represents a current position: X units of instrument Y on platform Z.
// Computed fields (avg cost, unrealized P&L, allocation %) are derived from operations
// at query time — they are never stored here.
model Holding {
  id           Int         @id @default(autoincrement())
  portfolioId  Int
  portfolio    Portfolio   @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  instrumentId Int
  instrument   Instrument  @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  platformId   Int?
  platform     Platform?   @relation(fields: [platformId], references: [id], onDelete: Cascade)
  operations   Operation[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

// A financial instrument (stock, ETF, bond, crypto, etc.)
// All prices are tracked in USD. Non-US instruments are tracked via their ADR listing.
model Instrument {
  id                Int              @id @default(autoincrement())
  symbol            String           @unique  // Ticker as listed on US exchange (e.g. "AAPL", "BABA")
  name              String
  exchange          String?          // Exchange where it trades (e.g. "NYSE", "NASDAQ")
  country           String?          // Country of origin (ISO 3166-1 alpha-2, e.g. "US", "CN")
  instrumentClassId Int
  instrumentClass   InstrumentClass  @relation(fields: [instrumentClassId], references: [id], onDelete: Restrict)
  holdings          Holding[]
  priceSnapshots    PriceSnapshot[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

// Classifies instruments: Stock, ETF, Bond, Crypto, Cash
model InstrumentClass {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  instruments Instrument[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// A broker or exchange where holdings are held (e.g. IBKR, Robinhood, Binance)
model Platform {
  id        Int          @id @default(autoincrement())
  name      String       @unique
  type      PlatformType
  holdings  Holding[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

// A buy, sell, dividend, or fee operation on a holding.
// All monetary values are in USD.
model Operation {
  id        Int           @id @default(autoincrement())
  holdingId Int
  holding   Holding       @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  type      OperationType
  quantity  Decimal       // Number of units (shares, coins, etc.). 0 for DIVIDEND and FEE.
  price     Decimal       // Price per unit for BUY/SELL. Total amount for DIVIDEND/FEE.
  fees      Decimal       @default(0) // Broker commission or transaction cost, in USD.
  date      DateTime
  notes     String?       // Optional free-text note from the user (e.g. "earnings play")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

// Daily closing price for an instrument.
// Used to compute portfolio value over time (the performance chart in the dashboard).
// Populated by a background job or manual import — never derived from operations.
model PriceSnapshot {
  id           Int        @id @default(autoincrement())
  instrumentId Int
  instrument   Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  date         DateTime   @db.Date          // One row per instrument per day
  closePrice   Decimal                      // Closing price in USD
  createdAt    DateTime   @default(now())

  @@unique([instrumentId, date])
}

enum PlatformType {
  BROKER
  EXCHANGE
  BANK
}

enum OperationType {
  BUY
  SELL
  DIVIDEND
  FEE
}

model RefreshToken {
  id              Int       @id @default(autoincrement())
  token           String    @unique       // SHA-256 hash of the raw token
  userId          Int
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires         DateTime
  createdByIp     String
  userAgent       String?
  revoked         DateTime?
  revokedByIp     String?
  replacedByToken String?   // hash of the token that replaced this one (audit trail)
  createdAt       DateTime  @default(now())
}
