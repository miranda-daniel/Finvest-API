{
  "name": "finvest-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "update-routes-and-swagger": "tsoa spec-and-routes",
    "start": "npm run update-routes-and-swagger && nodemon",
    "build": "npm run update-routes-and-swagger && tsc --outDir build && npm run copy-generated && tsc-alias",
    "dev": "docker compose -f docker-compose.dev.yml up",
    "dev:build": "docker compose -f docker-compose.dev.yml up --build",
    "copy-generated": "node -e \"const{cpSync,existsSync}=require('fs');if(existsSync('src/generated'))cpSync('src/generated','build/generated',{recursive:true,force:true})\"",
    "start:prod": "node build/index.js",
    "lint": "eslint .",
    "seed": "npx ts-node -r tsconfig-paths/register prisma/seed.ts",
    "lint-fix": "eslint . --fix",
    "test": "npx dotenv-cli -e .env.test -- jest ./src",
    "test-full": "npx dotenv-cli -e .env.test -- npx prisma migrate dev && npm run update-routes-and-swagger && npx dotenv-cli -e .env.test -- jest ./src",
    "postinstall": "npx prisma generate",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miranda-daniel/finvest.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/miranda-daniel/finvest/issues"
  },
  "homepage": "https://github.com/miranda-daniel/finvest#readme",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@faker-js/faker": "^8.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.2",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=10.5"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@graphql-tools/utils": "^8.13.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "graphql": "^16.13.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^7.8.0",
    "swagger-ui-express": "^5.0.0",
    "tsoa": "^5.1.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "!(src/routes|src/generated)/**/*.ts": [
      "npm run lint-fix"
    ]
  }
}
