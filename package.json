{
  "name": "finvest-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "update-routes-and-swagger": "tsoa spec-and-routes",
    "start": "npm run update-routes-and-swagger && npx dotenv-cli -e .env.development -- nodemon",
    "build": "npm run update-routes-and-swagger && tsc --outDir build && tsc-alias",
    "start:prod": "node build/index.js",
    "lint": "eslint .",
    "seed": "npx ts-node prisma/seed.ts",
    "lint-fix": "eslint . --fix",
    "test": "npx dotenv-cli -e .env.test -- jest ./src",
    "test-full": "npx dotenv-cli -e .env.test -- npx prisma migrate dev && npm run update-routes-and-swagger && npx dotenv-cli -e .env.test -- jest ./src",
    "postinstall": "npx prisma generate",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miranda-daniel/finvest.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/miranda-daniel/finvest/issues"
  },
  "homepage": "https://github.com/miranda-daniel/finvest#readme",
  "devDependencies": {
    "@faker-js/faker": "^8.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/validator": "^13.11.7",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "dotenv-cli": "^7.3.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.0.11",
    "jest": "^30.3.0",
    "lint-staged": "^15.2.2",
    "nodemon": "^3.0.2",
    "prettier": "^3.2.5",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": "20.13",
    "npm": "10.5"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@graphql-tools/utils": "8.0.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "graphql": "^16.13.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^7.6.0",
    "swagger-ui-express": "^5.0.0",
    "tsoa": "^5.1.1",
    "validator": "^13.11.0",
    "winston": "^3.15.0",
    "zod": "^4.3.6"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "!(src/routes|src/generated)/**/*.ts": [
      "npm run lint-fix"
    ]
  }
}
